---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { AstroSeo } from '@astrolib/seo';
import MenteeCard from '../../components/mentees/MenteeCard.astro';

const mentees = await getCollection('cohort-4');
---

<AstroSeo
  title="Mentees | DXMentorship"
  description="Showcase of our current mentees"
  canonical="https://www.dxmentorship.com"
  openGraph={{
    url: 'https://www.dxmentorship.com',
    title: 'DXMentorship Mentees',
    description: 'Showcase of our current mentees',
    images: [
      {
        url: '/opengraph/mentees-og.png',
        width: 1200,
        height: 630,
        alt: 'Social open graph',
        type: 'image/jpeg',
      },
    ],
    site_name: 'DXMentorship',
  }}
  twitter={{
    handle: '@dxmentorship',
    site: '@site',
    cardType: 'summary_large_image',
  }}
/>

<BaseLayout>
  <section>
    <div class="max-w-7xl px-8 md:px-12 lg:px-32 mx-auto py-32 lg:py-36 relative">
      <div class="max-w-2xl">
        <p class="text-sm text-transparent uppercase bg-gradient-to-r from-indigo-300 to-indigo-400 bg-clip-text">
          Our Mentees
        </p>
        <p class="mt-8 text-4xl font-normal tracking-tighter text-white sm:text-5xl">Meet Our Program Mentees</p>
        <p class="mt-4 text-vulcan-300">
          These talented individuals have successfully completed our DevRel mentorship program and are now making their
          mark in the industry.
        </p>
      </div>
      <div class="py-24">
        <ol class="grid grid-cols-1 gap-4 lg:grid-cols-3 sm:grid-cols-2" role="list">
          {mentees.map((mentee) => (
            <MenteeCard
              url={`/mentees/${mentee.slug}`}
              name={mentee.data.name}
              title={mentee.data.title}
              image={mentee.data.image}
            />
          ))}
        </ol>
      </div>
  </section>
</BaseLayout>